CREATE TABLE operations_tickets (
  ticket_id       INTEGER PRIMARY KEY,
  team            TEXT,    -- 'Content', 'Tech', 'Operations'
  category        TEXT,    -- 'Bug', 'Data Issue', 'Process Gap', 'Access Request'
  priority        TEXT,    -- 'High', 'Medium', 'Low'
  created_at      DATETIME,
  resolved_at     DATETIME,  -- NULL if still open
  sla_hours       INTEGER    -- agreed SLA window
);

