-- For SQLite / MySQL
SELECT
  ticket_id,
  team,
  category,
  priority,
  sla_hours,
  ROUND(
    (JULIANDAY(resolved_at) - JULIANDAY(created_at)) * 24,
    1
  ) AS hours_taken,
  CASE
    WHEN resolved_at IS NULL THEN 'Open'
    WHEN (JULIANDAY(resolved_at) - JULIANDAY(created_at)) * 24 <= sla_hours
      THEN 'SLA Met'
    ELSE 'SLA Breached'
  END AS sla_status
FROM operations_tickets;

SELECT
  team,
  COUNT(*) AS total_tickets,
  SUM(CASE
    WHEN resolved_at IS NOT NULL
     AND (JULIANDAY(resolved_at) - JULIANDAY(created_at)) * 24 <= sla_hours
    THEN 1 ELSE 0
  END) AS sla_met,
  SUM(CASE
    WHEN resolved_at IS NOT NULL
     AND (JULIANDAY(resolved_at) - JULIANDAY(created_at)) * 24 > sla_hours
    THEN 1 ELSE 0
  END) AS sla_breached,
  ROUND(
    100.0 * SUM(CASE
      WHEN resolved_at IS NOT NULL
       AND (JULIANDAY(resolved_at) - JULIANDAY(created_at)) * 24 <= sla_hours
      THEN 1 ELSE 0
    END) / COUNT(*),
    1
  ) AS compliance_pct
FROM operations_tickets
GROUP BY team
ORDER BY compliance_pct ASC;


SELECT
  category,
  COUNT(*) AS total,
  ROUND(
    AVG((JULIANDAY(resolved_at) - JULIANDAY(created_at)) * 24),
    1
  ) AS avg_hours_to_resolve
FROM operations_tickets
WHERE resolved_at IS NOT NULL
GROUP BY category
ORDER BY avg_hours_to_resolve DESC;

SELECT
  ticket_id,
  team,
  category,
  created_at,
  sla_hours,
  'Open - Needs Attention' AS flag
FROM operations_tickets
WHERE resolved_at IS NULL
  AND priority = 'High'
ORDER BY created_at ASC;
